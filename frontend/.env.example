# ================================
# CODEWITHBOTINA FRONTEND CONFIGURATION
# ================================

# Environment-specific configuration
# For local development, use localhost URLs
# For production (Cloudflare Pages), use production URLs

# Supabase
PUBLIC_SUPABASE_URL=http://localhost:54321  # or https://xxx.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Backend API
PUBLIC_API_URL=http://localhost:8000  # or https://api.codewithbotina.com

# Frontend Site
PUBLIC_SITE_URL=http://localhost:4321  # or https://blog.codewithbotina.com

# Google OAuth (optional for frontend display)
PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here

# Site Configuration
PUBLIC_SITE_NAME=CodeWithBotina
PUBLIC_SITE_DESCRIPTION=Technical blog about software development, web technologies, and programming best practices by Diego Alejandro Botina

# Author Information (for Schema.org and SEO)
PUBLIC_AUTHOR_NAME=Diego Alejandro Botina
PUBLIC_AUTHOR_EMAIL=support@codewithbotina.com
PUBLIC_AUTHOR_URL=https://portfolio.codewithbotina.com

# Social Media Links
PUBLIC_INSTAGRAM_URL=https://www.instagram.com/codewithbotina/
PUBLIC_FACEBOOK_URL=https://www.facebook.com/codewithbotina
PUBLIC_TIKTOK_URL=https://www.tiktok.com/@codewithbotina
PUBLIC_LINKEDIN_URL=https://www.linkedin.com/in/codewithbotinaoficial
PUBLIC_PATREON_URL=https://www.patreon.com/c/CodeWithBotina
PUBLIC_YOUTUBE_URL=https://www.youtube.com/@CodeWithBotina
PUBLIC_GITHUB_URL=https://github.com/CodeWithBotinaOficial
PUBLIC_PORTFOLIO_URL=https://portfolio.codewithbotina.com/

# Security:
# - Only PUBLIC_* variables are safe to expose to client
# - Never include service_role keys in frontend
# - All environment variables are embedded in the static build
