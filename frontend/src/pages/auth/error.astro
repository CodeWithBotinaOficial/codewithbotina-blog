---
export const prerender = false;

import { DEFAULT_LANGUAGE, detectLanguage, type SupportedLanguage } from "../../lib/i18n";

const language = (detectLanguage(
  Astro.cookies,
  Astro.request.headers.get("accept-language"),
) as SupportedLanguage) ?? DEFAULT_LANGUAGE;

const redirectUrl = new URL(`/${language}/auth/error`, Astro.url.origin);
for (const [key, value] of Astro.url.searchParams.entries()) {
  redirectUrl.searchParams.set(key, value);
}

return Astro.redirect(redirectUrl.toString(), 302);
---
