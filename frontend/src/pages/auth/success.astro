---
export const prerender = false;

import { DEFAULT_LANGUAGE, detectLanguage, isSupportedLanguage, type SupportedLanguage } from "../../lib/i18n";

const nextParam = Astro.url.searchParams.get("next") ?? "";

function extractLanguageFromNext(nextValue: string): SupportedLanguage | null {
  if (!nextValue) return null;
  try {
    const nextUrl = new URL(nextValue, "https://blog.codewithbotina.com");
    const match = nextUrl.pathname.match(/^\/(en|es)(\/|$)/);
    if (match && isSupportedLanguage(match[1])) {
      return match[1] as SupportedLanguage;
    }
  } catch (_error) {
    return null;
  }
  return null;
}

const nextLanguage = extractLanguageFromNext(nextParam);
const language = nextLanguage ??
  (detectLanguage(Astro.cookies, Astro.request.headers.get("accept-language")) as SupportedLanguage) ??
  DEFAULT_LANGUAGE;

const redirectUrl = new URL(`/${language}/auth/success`, Astro.url.origin);
if (nextParam) {
  redirectUrl.searchParams.set("next", nextParam);
}

return Astro.redirect(redirectUrl.toString(), 302);
---
