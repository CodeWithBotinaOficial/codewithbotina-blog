---
import BaseLayout from "../../components/BaseLayout.astro";
---

<BaseLayout
  title="Signed In"
  description="Authentication successful. Finalizing your session."
>
  <section class="container-responsive py-16">
    <h1>Sign-in successful</h1>
    <p>We are finalizing your session. You will be redirected shortly.</p>
  </section>

  <script>
    import { supabase } from "../../lib/supabase";

    const params = new URLSearchParams(window.location.search);
    const next = params.get("next");
    const apiUrl = "" + (import.meta.env.PUBLIC_API_URL || "https://api.codewithbotina.com");

    const finalize = async () => {
      const res = await fetch(`${apiUrl}/api/auth/refresh`, {
        method: "POST",
        credentials: "include",
      });

      if (res.ok) {
        const body = await res.json();
        if (body?.access_token && body?.refresh_token) {
          await supabase.auth.setSession({
            access_token: body.access_token,
            refresh_token: body.refresh_token,
          });
        }
      }

      if (next && next.startsWith("https://blog.codewithbotina.com/")) {
        window.location.assign(next);
        return;
      }
      window.location.assign("/");
    };

    finalize();
  </script>
</BaseLayout>
