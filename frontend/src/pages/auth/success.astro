---
export const prerender = false;

import BaseLayout from "../../components/BaseLayout.astro";
import { DEFAULT_LANGUAGE, detectLanguage, isSupportedLanguage, setLanguagePreference, t, type SupportedLanguage } from "../../lib/i18n";

const nextParam = Astro.url.searchParams.get("next") ?? "";

function extractLanguageFromNext(nextValue: string): SupportedLanguage | null {
  if (!nextValue) return null;
  try {
    const nextUrl = new URL(nextValue, "https://blog.codewithbotina.com");
    const match = nextUrl.pathname.match(/^\/(en|es)(\/|$)/);
    if (match && isSupportedLanguage(match[1])) {
      return match[1] as SupportedLanguage;
    }
  } catch (_error) {
    return null;
  }
  return null;
}

const nextLanguage = extractLanguageFromNext(nextParam);
const detected = detectLanguage(Astro.cookies, Astro.request.headers.get("accept-language"));
const language = nextLanguage ?? detected ?? DEFAULT_LANGUAGE;
setLanguagePreference(Astro.cookies, language);
---

<BaseLayout
  title={t(language, "successTitle", "auth")}
  description={t(language, "successMessage", "auth")}
  currentLanguage={language}
  currentPath={Astro.url.pathname}
>
  <section class="container-responsive py-16">
    <h1>{t(language, "successTitle", "auth")}</h1>
    <p>{t(language, "successMessage", "auth")}</p>
    <p class="mt-3 text-sm text-[var(--color-text-tertiary)]">
      {t(language, "redirecting", "auth")}
    </p>
  </section>

  <script type="module" define:vars={{ language }}>
    import { supabase } from "../../lib/supabase";
    import { getApiUrl } from "../../lib/env";

    const params = new URLSearchParams(window.location.search);
    const next = params.get("next");
    const apiUrl = getApiUrl();

    const syncCookies = async (refreshToken) => {
      if (!refreshToken) return null;
      const res = await fetch(`${apiUrl}/api/auth/refresh`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        credentials: "include",
        body: JSON.stringify({ refresh_token: refreshToken }),
      });
      if (!res.ok) return null;
      const body = await res.json();
      if (body?.access_token && body?.refresh_token) {
        return body;
      }
      return null;
    };

    const verifySession = async (accessToken) => {
      if (!accessToken) return false;
      const res = await fetch(`${apiUrl}/api/auth/me`, {
        headers: { Authorization: `Bearer ${accessToken}` },
        credentials: "include",
      });
      return res.ok;
    };

    const finalize = async () => {
      const hashParams = new URLSearchParams(window.location.hash.slice(1));
      const accessToken = hashParams.get("access_token");
      const refreshToken = hashParams.get("refresh_token");

      if (accessToken && refreshToken) {
        await supabase.auth.setSession({
          access_token: accessToken,
          refresh_token: refreshToken,
        });
        const refreshed = await syncCookies(refreshToken);
        if (refreshed?.access_token && refreshed?.refresh_token) {
          await supabase.auth.setSession({
            access_token: refreshed.access_token,
            refresh_token: refreshed.refresh_token,
          });
        }
        window.history.replaceState({}, "", window.location.pathname + window.location.search);
      } else {
        const res = await fetch(`${apiUrl}/api/auth/refresh`, {
          method: "POST",
          credentials: "include",
        });

        if (res.ok) {
          const body = await res.json();
          if (body?.access_token && body?.refresh_token) {
            await supabase.auth.setSession({
              access_token: body.access_token,
              refresh_token: body.refresh_token,
            });
          }
        }
      }

      const session = await supabase.auth.getSession();
      const ok = await verifySession(session.data.session?.access_token);
      if (!ok) {
        window.location.assign("/auth/error");
        return;
      }

      if (next) {
        if (next.startsWith("https://blog.codewithbotina.com/")) {
          window.location.assign(next);
          return;
        }
        if (next.startsWith("/")) {
          window.location.assign(next);
          return;
        }
      }
      window.location.assign(`/${language}/`);
    };

    finalize();
  </script>
</BaseLayout>
