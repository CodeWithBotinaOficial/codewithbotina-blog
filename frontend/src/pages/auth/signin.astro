---
export const prerender = false;

import BaseLayout from "../../components/BaseLayout.astro";
import SignInButton from "../../components/auth/SignInButton.astro";
import { DEFAULT_LANGUAGE, detectLanguage, setLanguagePreference, t, type SupportedLanguage } from "../../lib/i18n";

const language = detectLanguage(Astro.cookies, Astro.request.headers.get("accept-language")) as SupportedLanguage;
setLanguagePreference(Astro.cookies, language);
---

<BaseLayout
  title={t(language, "signInTitle", "auth")}
  description={t(language, "signInDescription", "auth")}
  currentLanguage={language}
  currentPath={Astro.url.pathname}
>
  <section class="container-responsive py-16">
    <h1>{t(language, "signInTitle", "auth")}</h1>
    <p>{t(language, "signInDescription", "auth")}</p>
    <SignInButton label={t(language, "signInWithGoogle", "auth")} />
  </section>
</BaseLayout>
