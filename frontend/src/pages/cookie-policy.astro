---
import BaseLayout from '../components/BaseLayout.astro';
import { marked } from 'marked';
import fs from 'node:fs';
import path from 'node:path';

const policyPath = path.join(process.cwd(), '..', 'legal-docs', 'cookie-policy.md');
const markdown = fs.readFileSync(policyPath, 'utf-8');
const html = marked.parse(markdown);
---

<BaseLayout
  title="Política de Cookies"
  description="Política de cookies de CodeWithBotina."
>
  <section class="container-responsive py-12">
    <article class="prose prose-lg max-w-none" set:html={html} />
  </section>
</BaseLayout>
