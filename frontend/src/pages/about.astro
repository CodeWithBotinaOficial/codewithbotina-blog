---
import BaseLayout from "../components/BaseLayout.astro";
import { ArrowRight } from "lucide-astro";
import { marked } from "marked";
import fs from "node:fs";
import path from "node:path";

const aboutPath = path.join(process.cwd(), "..", "content", "about.md");
const markdown = fs.readFileSync(aboutPath, "utf-8");
const html = marked.parse(markdown);
---

<BaseLayout 
  title="About Diego Botina" 
  description="Learn about Diego Alejandro Botina, software developer and creator of CodeWithBotina technical blog."
>
  <!-- Hero -->
  <section class="bg-[var(--color-bg-subtle)] py-20 border-b border-[var(--color-border)]">
    <div class="container-responsive text-center">
      <div class="w-32 h-32 mx-auto bg-white rounded-full shadow-lg mb-6 overflow-hidden border-4 border-white">
        <img 
          src="/avatar.webp" 
          alt="Diego Alejandro Botina"
          class="w-full h-full object-cover"
        />
      </div>
      <h1 class="text-4xl font-bold mb-4">About CodeWithBotina</h1>
      <p class="text-xl text-[var(--color-text-secondary)] max-w-2xl mx-auto">
        Sharing insights, tutorials, and lessons learned from real-world software development.
      </p>
    </div>
  </section>

  <!-- Content -->
  <section class="py-16">
    <div class="container-responsive max-w-3xl">
      <article class="prose prose-lg mb-16" set:html={html} />

      <!-- Connect -->
      <div class="bg-[var(--color-bg-subtle)] rounded-2xl p-8 md:p-12 text-center">
        <h2 class="text-3xl font-bold mb-6">Let's Connect!</h2>
        <p class="text-[var(--color-text-secondary)] mb-8 max-w-xl mx-auto">
          Interested in working together or have questions? You can find me on social media or reach out via the contact form.
        </p>
        
        <div class="flex flex-col sm:flex-row justify-center gap-4">
          <a href="/contact" class="btn-primary flex items-center justify-center gap-2">
            Get in Touch <ArrowRight size={20} />
          </a>
          <a href="https://portfolio.codewithbotina.com" target="_blank" class="px-6 py-3 rounded-lg border border-[var(--color-border)] bg-white hover:bg-gray-50 font-semibold transition-colors flex items-center justify-center gap-2">
            View Portfolio <ArrowRight size={20} />
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
