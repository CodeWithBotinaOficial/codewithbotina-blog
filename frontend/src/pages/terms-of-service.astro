---
import BaseLayout from '../components/BaseLayout.astro';
import { marked } from 'marked';
import fs from 'node:fs';
import path from 'node:path';

const policyPath = path.join(process.cwd(), '..', 'legal-docs', 'terms-of-service.md');
const markdown = fs.readFileSync(policyPath, 'utf-8');
const html = marked.parse(markdown);
---

<BaseLayout
  title="Términos de Servicio"
  description="Términos de servicio de CodeWithBotina para el uso de la plataforma."
>
  <section class="container-responsive py-12">
    <article class="prose prose-lg max-w-none" set:html={html} />
  </section>
</BaseLayout>
