---
export const prerender = false;

import BaseLayout from "../../../components/BaseLayout.astro";
import { DEFAULT_LANGUAGE, isSupportedLanguage, setLanguagePreference, t, type SupportedLanguage } from "../../../lib/i18n";

const { lang } = Astro.params;
const language = isSupportedLanguage(lang ?? "") ? (lang as SupportedLanguage) : DEFAULT_LANGUAGE;

if (!lang || !isSupportedLanguage(lang)) {
  return Astro.redirect(`/${DEFAULT_LANGUAGE}/`);
}

setLanguagePreference(Astro.cookies, language);
---

<BaseLayout
  title={t(language, "successTitle", "auth")}
  description={t(language, "successMessage", "auth")}
  currentLanguage={language}
  currentPath={Astro.url.pathname}
>
  <section class="container-responsive py-16">
    <h1>{t(language, "successTitle", "auth")}</h1>
    <p>{t(language, "successMessage", "auth")}</p>
    <p class="mt-3 text-sm text-[var(--color-text-tertiary)]">
      {t(language, "redirecting", "auth")}
    </p>
  </section>

  <script type="module" define:vars={{ language }}>
    import { setAuthState } from "../../../lib/auth-state";

    const params = new URLSearchParams(window.location.search);
    const next = params.get("next");

    const resolveNextTarget = (value) => {
      if (!value) return null;
      try {
        const resolved = new URL(value, window.location.origin);
        if (resolved.origin !== window.location.origin) return null;
        return resolved.toString();
      } catch (_error) {
        return null;
      }
    };

    const finalize = async () => {
      setAuthState(true);
      window.dispatchEvent(new Event("cwb:auth-changed"));
      const target = resolveNextTarget(next) ?? `/${language}/`;
      window.location.replace(target);
    };

    window.setTimeout(finalize, 50);
  </script>
</BaseLayout>
