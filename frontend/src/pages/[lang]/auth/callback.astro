---
export const prerender = false;

import BaseLayout from "../../../components/BaseLayout.astro";
import { DEFAULT_LANGUAGE, isSupportedLanguage, type SupportedLanguage } from "../../../lib/i18n";

const { lang } = Astro.params;
const language = isSupportedLanguage(lang ?? "") ? (lang as SupportedLanguage) : DEFAULT_LANGUAGE;
---

<BaseLayout
  title={language === "es" ? "Iniciando sesión" : "Signing in"}
  description={language === "es" ? "Completando autenticación..." : "Completing authentication..."}
  currentLanguage={language}
  currentPath={Astro.url.pathname}
>
  <section class="container-responsive py-16">
    <h1>{language === "es" ? "Iniciando sesión..." : "Signing you in..."}</h1>
    <p>{language === "es" ? "Completando autenticación. Espera un momento." : "Completing authentication. Please wait."}</p>
  </section>
</BaseLayout>
