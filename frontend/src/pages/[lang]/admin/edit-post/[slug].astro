---
export const prerender = false;

import BaseLayout from "../../../../components/BaseLayout.astro";
import PostEditor from "../../../../components/admin/PostEditor";
import { supabase } from "../../../../lib/supabase";
import { formatDate } from "../../../../lib/utils";
import { DEFAULT_LANGUAGE, isSupportedLanguage, t, type SupportedLanguage } from "../../../../lib/i18n";
import { getPostEditorLabels, getTagSelectorLabels } from "../../../../lib/admin-editor";

const { slug, lang } = Astro.params;
const language = isSupportedLanguage(lang ?? "") ? (lang as SupportedLanguage) : DEFAULT_LANGUAGE;

if (!lang || !isSupportedLanguage(lang)) {
  return Astro.redirect(`/${DEFAULT_LANGUAGE}/`);
}

let post: any = null;
let postError: any = null;

let joinedQuery = supabase
  .from("posts")
  .select(`
    *,
    post_tags (
      tag:tags (
        id,
        name,
        slug,
        usage_count
      )
    )
  `)
  .eq("slug", slug)
  .eq("language", language);

const joinedResult = await joinedQuery.single();

if (joinedResult.error) {
  const fallback = await supabase
    .from("posts")
    .select("*")
    .eq("slug", slug)
    .eq("language", language)
    .single();
  post = fallback.data;
  postError = fallback.error;
} else {
  post = joinedResult.data;
}

if (postError || !post) {
  return Astro.redirect(`/${language}/404`);
}

const locale = language === "es" ? "es-ES" : "en-US";
const createdAt = post.fecha ? formatDate(post.fecha, locale) : t(language, "editor.unknownDate", "admin");
const updatedAt = post.updated_at ? formatDate(post.updated_at, locale) : null;
const tags = Array.isArray(post?.post_tags)
  ? (post.post_tags
      .map((item: { tag?: { id: string; name: string; slug: string; usage_count?: number } }) => item.tag)
      .filter(Boolean))
  : [];
const initialData = { ...post, tags, language };
const editorLabels = getPostEditorLabels(language);
const tagLabels = getTagSelectorLabels(language);
const pageTitle = t(language, "editPost", "admin");
---

<BaseLayout title={`${pageTitle}: ${post.titulo}`} currentLanguage={language} currentPath={Astro.url.pathname}>
  <section class="container-responsive py-12">
    <div class="mb-6">
      <h1 class="text-3xl font-bold">{pageTitle}: {post.titulo}</h1>
      <p class="mt-2 text-sm text-[var(--color-text-tertiary)]">
        {t(language, "editor.createdLabel", "admin")}: {createdAt}
        {updatedAt ? ` • ${t(language, "editor.updatedLabel", "admin")}: ${updatedAt}` : ""}
      </p>
    </div>

    <PostEditor
      mode="edit"
      initialData={initialData}
      cancelHref={`/${language}/posts/${post.slug}`}
      labels={editorLabels}
      tagLabels={tagLabels}
      client:load
    />
  </section>
</BaseLayout>
