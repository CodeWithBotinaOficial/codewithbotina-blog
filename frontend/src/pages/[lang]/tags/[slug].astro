---
export const prerender = false;

import BaseLayout from "../../../components/BaseLayout.astro";
import PostCard from "../../../components/PostCard.astro";
import PaginationControls from "../../../components/pagination/PaginationControls";
import SearchFiltersController from "../../../components/search/SearchFiltersController";
import { supabase } from "../../../lib/supabase";
import { getApiUrl, getSiteUrl } from "../../../lib/env";
import { DEFAULT_LANGUAGE, isSupportedLanguage, SUPPORTED_LANGUAGES, t, type SupportedLanguage } from "../../../lib/i18n";
import { filtersFromUrl } from "../../../lib/search-filters";
import {
  DEFAULT_PER_PAGE,
  buildPageHref,
  normalizePage,
  offsetFor,
  parsePage,
  parsePerPage,
  totalPagesFor,
  type AllowedPerPage,
} from "../../../lib/pagination";
import type { Post } from "../../../types/post";

const { slug, lang } = Astro.params;
const language = isSupportedLanguage(lang ?? "") ? (lang as SupportedLanguage) : DEFAULT_LANGUAGE;

if (!lang || !isSupportedLanguage(lang)) {
  return Astro.redirect(`/${DEFAULT_LANGUAGE}/`);
}

const apiUrl = getApiUrl();

let tag: { id: string; name: string; slug: string; description?: string | null } | null = null;
let posts: Post[] = [];
let hasTagError = false;
let hasPostsError = false;
let totalPosts = 0;
let searchPhase: string | null = null;

const requestedPerPage = parsePerPage(Astro.url.searchParams.get("per_page"));
const perPage = (requestedPerPage ?? DEFAULT_PER_PAGE) as AllowedPerPage;
const requestedPageRaw = parsePage(Astro.url.searchParams.get("page"));
const requestedPage = requestedPageRaw ?? 1;

const paginationKeys = new Set(["page", "per_page"]);
const hasOtherParams = Array.from(Astro.url.searchParams.keys()).some((key) => !paginationKeys.has(key));
const initialFilters = filtersFromUrl(Astro.url.searchParams, language);

const tagResult = await supabase
  .from("tags")
  .select("id, name, slug, description")
  .eq("slug", slug)
  .single();

if (!tagResult.error && tagResult.data) {
  tag = tagResult.data;

  if (hasOtherParams) {
    try {
      const safePage = requestedPage > 0 ? requestedPage : 1;
      const offset = offsetFor(safePage, perPage);
      const searchUrl = new URL(`${apiUrl}/api/posts/search`);
      if (initialFilters.search.trim()) searchUrl.searchParams.set("q", initialFilters.search.trim());
      if (initialFilters.from) searchUrl.searchParams.set("from", initialFilters.from);
      if (initialFilters.to) searchUrl.searchParams.set("to", initialFilters.to);
      if (initialFilters.relevance) searchUrl.searchParams.set("relevance", initialFilters.relevance);
      if (initialFilters.sort) searchUrl.searchParams.set("sort", initialFilters.sort);
      if (initialFilters.scope) searchUrl.searchParams.set("scope", initialFilters.scope);
      searchUrl.searchParams.set("tag_slug", tag.slug);
      searchUrl.searchParams.set("language", language);
      searchUrl.searchParams.set("limit", String(perPage));
      searchUrl.searchParams.set("offset", String(offset));

      const res = await fetch(searchUrl.toString());
      if (!res.ok) throw new Error("Failed to fetch tag search results");
      const payload = await res.json();
      const data = payload?.data ?? payload;
      totalPosts = (data?.total ?? 0) as number;
      posts = (data?.posts ?? []) as Post[];
      searchPhase = (data?.phase ?? null) as string | null;
    } catch (_err) {
      hasPostsError = true;
    }
  } else {
    const { count: totalCount, error: countError } = await supabase
      .from("posts")
      .select("id, post_tags!inner(tag_id)", { count: "exact", head: true })
      .eq("language", language)
      .eq("post_tags.tag_id", tag.id);

    if (countError) {
      hasTagError = true;
    } else {
      totalPosts = totalCount ?? 0;
    }

    const totalPages = totalPagesFor(totalPosts, perPage);
    const currentPage = normalizePage(requestedPage, totalPages);

    const invalidPerPageProvided = Astro.url.searchParams.has("per_page") && !requestedPerPage;
    const invalidPageProvided = Astro.url.searchParams.has("page") && requestedPageRaw === null;
    const outOfRange = currentPage !== requestedPage;
    const missingPageForCustomPerPage = perPage !== DEFAULT_PER_PAGE && !Astro.url.searchParams.has("page");
    const canonicalizeBase = currentPage === 1 && perPage === DEFAULT_PER_PAGE &&
      (Astro.url.searchParams.has("page") || Astro.url.searchParams.has("per_page"));

    if (!hasTagError && (invalidPerPageProvided || invalidPageProvided || outOfRange || missingPageForCustomPerPage || canonicalizeBase)) {
      return Astro.redirect(buildPageHref(`/${language}/tags/${slug}`, currentPage, perPage, Astro.url.searchParams), 302);
    }

    const offset = offsetFor(currentPage, perPage);
    const { data: pagePosts, error: pageError } = await supabase
      .from("posts")
      .select("id, titulo, slug, body, imagen_url, fecha, language, post_tags!inner(tag_id)")
      .eq("language", language)
      .eq("post_tags.tag_id", tag.id)
      .order("fecha", { ascending: false })
      .range(offset, offset + perPage - 1);

    if (!pageError) {
      posts = (pagePosts ?? []).map((row: any) => ({
        id: row.id,
        titulo: row.titulo,
        slug: row.slug,
        body: row.body,
        imagen_url: row.imagen_url,
        fecha: row.fecha,
        language: row.language,
      })) as Post[];
    } else {
      hasTagError = true;
    }
  }
} else {
  hasTagError = true;
}

if (hasTagError) {
  try {
    const safePage = requestedPage > 0 ? requestedPage : 1;
    const offset = offsetFor(safePage, perPage);
    const response = await fetch(
      `${apiUrl}/api/tags/${encodeURIComponent(slug ?? "")}?language=${encodeURIComponent(language)}&limit=${encodeURIComponent(String(perPage))}&offset=${encodeURIComponent(String(offset))}`,
    );
    if (response.ok) {
      const payload = await response.json();
      tag = payload?.data?.tag ?? payload?.tag ?? null;
      totalPosts = payload?.data?.total_posts ?? payload?.total_posts ?? 0;
      posts = (payload?.data?.posts ?? payload?.posts ?? []) as Post[];
      hasTagError = !tag;
    } else {
      hasTagError = true;
    }
  } catch (_error) {
    hasTagError = true;
  }
}

if (!tag || hasTagError) {
  return Astro.redirect(`/${language}/404`);
}

const siteUrl = getSiteUrl().replace(/\/$/, "");
const totalPages = totalPagesFor(totalPosts, perPage);
const currentPage = normalizePage(requestedPage, totalPages);
const invalidPerPageProvided = Astro.url.searchParams.has("per_page") && !requestedPerPage;
const invalidPageProvided = Astro.url.searchParams.has("page") && requestedPageRaw === null;
const outOfRange = currentPage !== requestedPage;
const missingPageForCustomPerPage = perPage !== DEFAULT_PER_PAGE && !Astro.url.searchParams.has("page");
const canonicalizeBase = !hasOtherParams && currentPage === 1 && perPage === DEFAULT_PER_PAGE &&
  (Astro.url.searchParams.has("page") || Astro.url.searchParams.has("per_page"));

if (invalidPerPageProvided || invalidPageProvided || outOfRange || missingPageForCustomPerPage || canonicalizeBase) {
  return Astro.redirect(buildPageHref(`/${language}/tags/${tag.slug}`, currentPage, perPage, Astro.url.searchParams), 302);
}

const canonicalPath = !hasOtherParams && currentPage === 1 && perPage === DEFAULT_PER_PAGE
  ? `/${language}/tags/${tag.slug}`
  : buildPageHref(`/${language}/tags/${tag.slug}`, currentPage, perPage, Astro.url.searchParams);
const canonicalUrl = `${siteUrl}${canonicalPath}`;
const prevPath = currentPage > 1 ? buildPageHref(`/${language}/tags/${tag.slug}`, currentPage - 1, perPage, Astro.url.searchParams) : null;
const nextPath = currentPage < totalPages ? buildPageHref(`/${language}/tags/${tag.slug}`, currentPage + 1, perPage, Astro.url.searchParams) : null;
const pageTitle = `#${tag.name}`;
const metaDescription = tag.description
  ? `${tag.description} (${totalPosts})`
  : t(language, "tagsDescription", "post");
const alternateLinks = SUPPORTED_LANGUAGES.map((lang) => ({
  lang,
  href: `${siteUrl}${buildPageHref(`/${lang}/tags/${tag.slug}`, currentPage, perPage)}`,
}));

const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: pageTitle,
  description: metaDescription,
  url: canonicalUrl,
  inLanguage: language,
  about: {
    "@type": "Thing",
    name: tag.name,
  },
  mainEntity: {
    "@type": "ItemList",
    numberOfItems: totalPosts,
    itemListElement: posts.map((post, index) => ({
      "@type": "ListItem",
      position: index + 1,
      url: `${siteUrl}/${language}/posts/${post.slug}`,
    })),
  },
};

const countLabel = totalPosts === 1
  ? t(language, "tagPostsCount", "post", { count: totalPosts })
  : t(language, "tagPostsCountPlural", "post", { count: totalPosts });

const paginationLabels = {
  previous: t(language, "pagination.previous"),
  next: t(language, "pagination.next"),
  page: t(language, "pagination.page"),
  of: t(language, "pagination.of"),
  postsPerPage: t(language, "pagination.postsPerPage"),
  show: t(language, "pagination.show"),
  goToPage: t(language, "pagination.goToPage"),
  currentPage: t(language, "pagination.currentPage"),
};
---

<BaseLayout
  title={pageTitle}
  description={metaDescription}
  canonical={canonicalUrl}
  currentLanguage={language}
  currentPath={Astro.url.pathname}
>
  <Fragment slot="head">
    {alternateLinks.map((link) => (
      <link rel="alternate" hreflang={link.lang} href={link.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}/en/tags/${tag.slug}`} />
    {prevPath ? <link rel="prev" href={`${siteUrl}${prevPath}`} /> : null}
    {nextPath ? <link rel="next" href={`${siteUrl}${nextPath}`} /> : null}
    <script type="application/ld+json">
      {JSON.stringify(structuredData)}
    </script>
  </Fragment>

  <section class="container-responsive py-12">
    <div class="mb-8">
      <h1 class="text-3xl md:text-4xl font-bold mb-2">#{tag.name}</h1>
      {tag.description && (
        <p class="text-[var(--color-text-secondary)] max-w-2xl">{tag.description}</p>
      )}
      <p class="text-sm text-[var(--color-text-tertiary)] mt-2">{countLabel}</p>
    </div>

    <div class="mb-10">
      <SearchFiltersController
        basePath={`/${language}/tags/${tag.slug}`}
        initialFilters={initialFilters}
        showLanguageFilter={false}
        showTagFilter={false}
        client:load
      />
    </div>

    {hasOtherParams && initialFilters.search.trim() && searchPhase === "content" ? (
      <div class="mb-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-subtle)] px-4 py-3 text-sm text-[var(--color-text-secondary)]">
        {t(language, "search.foundInContent")}
      </div>
    ) : null}
    {hasOtherParams && initialFilters.search.trim() && searchPhase === "tags" ? (
      <div class="mb-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-subtle)] px-4 py-3 text-sm text-[var(--color-text-secondary)]">
        {t(language, "search.foundInTags", "common", { term: initialFilters.search.trim() })}
      </div>
    ) : null}

    {hasPostsError ? (
      <div class="text-center py-12">
        <p class="text-xl text-[var(--color-error)]">{t(language, "errors.fetchPosts")}</p>
      </div>
    ) : posts.length === 0 ? (
      <div class="text-center py-12 text-[var(--color-text-secondary)]">
        {t(language, "noTagPosts", "post")}
      </div>
    ) : (
      <>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {posts.map((post) => (
            <PostCard post={post} language={language} />
          ))}
        </div>
        <PaginationControls
          currentPage={currentPage}
          totalPages={totalPages}
          perPage={perPage}
          baseUrl={`/${language}/tags/${tag.slug}`}
          labels={paginationLabels}
          client:load
        />
      </>
    )}
  </section>
</BaseLayout>
