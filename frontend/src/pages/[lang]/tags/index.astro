---
export const prerender = false;

import BaseLayout from "../../../components/BaseLayout.astro";
import { supabase } from "../../../lib/supabase";
import { getApiUrl, getSiteUrl } from "../../../lib/env";
import { DEFAULT_LANGUAGE, getLocalizedPath, isSupportedLanguage, SUPPORTED_LANGUAGES, t, type SupportedLanguage } from "../../../lib/i18n";
import TagSearchBar from "../../../components/tags/TagSearchBar";
import TagPaginationControls from "../../../components/pagination/TagPaginationControls";
import {
  buildTagsPageHref,
  getTagsPaginationState,
  normalizePage,
  offsetFor,
  totalPagesForTags,
  type AllowedTagsPerPage,
} from "../../../lib/tag-pagination";

const { lang } = Astro.params;
const language = isSupportedLanguage(lang ?? "") ? (lang as SupportedLanguage) : DEFAULT_LANGUAGE;

if (!lang || !isSupportedLanguage(lang)) {
  return Astro.redirect(`/${DEFAULT_LANGUAGE}/`);
}

const apiUrl = getApiUrl();
const siteUrl = getSiteUrl().replace(/\/$/, "");

const query = (Astro.url.searchParams.get("q") ?? "").trim();
const sort = (Astro.url.searchParams.get("sort") ?? "most_used").trim() as "most_used" | "az" | "za" | "recent";
const languageFilterRaw = (Astro.url.searchParams.get("language") ?? "").trim().toLowerCase();
const languageFilter = languageFilterRaw || language; // default: current UI language

const { requestedPerPage, perPage, requestedPageRaw, requestedPage } = getTagsPaginationState(Astro.url.searchParams);

const invalidPerPageProvided = Astro.url.searchParams.has("per_page") && !requestedPerPage;
const invalidPageProvided = Astro.url.searchParams.has("page") && requestedPageRaw === null;

let tags: Array<{
  id: string;
  name: string;
  slug: string;
  description?: string | null;
  usage_count?: number | null;
  usage_count_language?: number | null;
  updated_at?: string | null;
  created_at?: string | null;
}> = [];

let hasError = false;
let totalTags = 0;

try {
  const offset = offsetFor(requestedPage > 0 ? requestedPage : 1, perPage);
  const url = new URL(`${apiUrl.replace(/\/$/, "")}/api/tags`);
  if (query) url.searchParams.set("q", query);
  if (sort) url.searchParams.set("sort", sort);
  if (languageFilter) url.searchParams.set("language", languageFilter);
  url.searchParams.set("limit", String(perPage));
  url.searchParams.set("offset", String(offset));

  const response = await fetch(url.toString());
  if (!response.ok) throw new Error("Failed to fetch tags");
  const payload = await response.json();
  const data = payload?.data ?? payload;
  tags = (data?.tags ?? []) as any[];
  totalTags = (data?.total ?? tags.length ?? 0) as number;
} catch (_err) {
  hasError = true;
  // Fall back to direct Supabase query (no language-scoped usage counts).
  const tagResult = await supabase
    .from("tags")
    .select("id, name, slug, description, usage_count, updated_at, created_at", { count: "exact" })
    .ilike("name", query ? `%${query}%` : "%")
    .order(sort === "az" ? "name" : sort === "za" ? "name" : sort === "recent" ? "created_at" : "usage_count", {
      ascending: sort === "az",
    })
    .range(offsetFor(requestedPage > 0 ? requestedPage : 1, perPage), offsetFor(requestedPage > 0 ? requestedPage : 1, perPage) + perPage - 1);

  if (!tagResult.error) {
    tags = tagResult.data ?? [];
    totalTags = tagResult.count ?? tags.length;
    hasError = false;
  }
}

const totalPages = totalPagesForTags(totalTags, perPage);
const currentPage = normalizePage(requestedPage, totalPages);
const outOfRange = currentPage !== requestedPage;
const missingPageForCustomPerPage = perPage !== 20 && !Astro.url.searchParams.has("page");
const canonicalizeBase = currentPage === 1 && perPage === 20 &&
  (Astro.url.searchParams.has("page") || Astro.url.searchParams.has("per_page"));

if (!hasError && (invalidPerPageProvided || invalidPageProvided || outOfRange || missingPageForCustomPerPage || canonicalizeBase)) {
  return Astro.redirect(buildTagsPageHref(`/${language}/tags`, currentPage, perPage, Astro.url.searchParams), 302);
}

const canonicalUrl = `${siteUrl}/${language}/tags`;
const pageTitle = t(language, "tagsTitle", "post");
const metaDescription = t(language, "tagsDescription", "post");
const alternateLinks = SUPPORTED_LANGUAGES.map((lang) => ({
  lang,
  href: `${siteUrl}${getLocalizedPath(Astro.url.pathname, lang)}`,
}));

const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: pageTitle,
  description: metaDescription,
  url: canonicalUrl,
  inLanguage: language,
  mainEntity: {
    "@type": "ItemList",
    numberOfItems: totalTags,
    itemListElement: tags.map((tag, index) => ({
      "@type": "ListItem",
      position: index + 1,
      url: `${siteUrl}/${language}/tags/${tag.slug}`,
    })),
  },
};

const paginationLabels = {
  previous: t(language, "pagination.previous"),
  next: t(language, "pagination.next"),
  page: t(language, "pagination.page"),
  of: t(language, "pagination.of"),
  perPage: t(language, "tagPage.perPage"),
  show: t(language, "pagination.show"),
  goToPage: t(language, "pagination.goToPage"),
  currentPage: t(language, "pagination.currentPage"),
};
---

<BaseLayout
  title={pageTitle}
  description={metaDescription}
  canonical={canonicalUrl}
  currentLanguage={language}
  currentPath={Astro.url.pathname}
>
  <Fragment slot="head">
    {alternateLinks.map((link) => (
      <link rel="alternate" hreflang={link.lang} href={link.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}/en/tags`} />
    <script type="application/ld+json">
      {JSON.stringify(structuredData)}
    </script>
  </Fragment>

  <section class="container-responsive py-12">
    <div class="mb-8">
      <h1 class="text-3xl md:text-4xl font-bold mb-2">{pageTitle}</h1>
      <p class="text-[var(--color-text-secondary)] max-w-2xl">{metaDescription}</p>
    </div>

    <div class="mb-10">
      <TagSearchBar
        uiLanguage={language}
        basePath={`/${language}/tags`}
        initialQuery={query}
        initialSort={sort}
        initialLanguageFilter={languageFilter}
        client:load
      />
    </div>

    {hasError ? (
      <div class="text-center py-12">
        <p class="text-xl text-[var(--color-error)]">{t(language, "errors.fetchPosts")}</p>
      </div>
    ) : tags.length === 0 ? (
      <div class="text-center py-12 text-[var(--color-text-secondary)]">
        {t(language, "tagsEmpty", "post")}
      </div>
    ) : (
      <>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {tags.map((tag) => {
            const count = tag.usage_count_language ?? tag.usage_count ?? 0;
            const usageLabel = t(language, "tagPage.postsCount", "common", { count });

            return (
              <a
                href={`/${language}/tags/${tag.slug}`}
                class="border border-[var(--color-border)] rounded-xl p-5 hover:shadow-lg transition"
              >
                <p class="text-lg font-semibold mb-1">#{tag.name}</p>
                <p class="text-sm text-[var(--color-text-secondary)]">
                  {tag.description || t(language, "tagDescriptionFallback", "post")}
                </p>
                <p class="text-xs text-[var(--color-text-tertiary)] mt-3">{usageLabel}</p>
              </a>
            );
          })}
        </div>

        <TagPaginationControls
          currentPage={currentPage}
          totalPages={totalPages}
          perPage={perPage as AllowedTagsPerPage}
          baseUrl={`/${language}/tags`}
          labels={paginationLabels}
          client:load
        />
      </>
    )}
  </section>
</BaseLayout>
