---
export const prerender = false;

import BaseLayout from "../../components/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import AdminCreatePostButton from "../../components/admin/AdminCreatePostButton";
import PaginationControls from "../../components/pagination/PaginationControls";
import SearchFiltersController from "../../components/search/SearchFiltersController";
import { supabase } from "../../lib/supabase";
import { getApiUrl, getSiteUrl } from "../../lib/env";
import type { Post } from "../../types/post";
import { DEFAULT_LANGUAGE, isSupportedLanguage, SUPPORTED_LANGUAGES, t, type SupportedLanguage } from "../../lib/i18n";
import {
  DEFAULT_PER_PAGE,
  buildPageHref,
  normalizePage,
  offsetFor,
  parsePage,
  parsePerPage,
  totalPagesFor,
  type AllowedPerPage,
} from "../../lib/pagination";
import { filtersFromUrl } from "../../lib/search-filters";

const { lang } = Astro.params;
const language = isSupportedLanguage(lang ?? "") ? (lang as SupportedLanguage) : DEFAULT_LANGUAGE;

if (!lang || !isSupportedLanguage(lang)) {
  return Astro.redirect(`/${DEFAULT_LANGUAGE}/`);
}

const requestedPerPage = parsePerPage(Astro.url.searchParams.get("per_page"));
const perPage = (requestedPerPage ?? DEFAULT_PER_PAGE) as AllowedPerPage;
const requestedPageRaw = parsePage(Astro.url.searchParams.get("page"));
const requestedPage = requestedPageRaw ?? 1;

const invalidPerPageProvided = Astro.url.searchParams.has("per_page") && !requestedPerPage;
const invalidPageProvided = Astro.url.searchParams.has("page") && requestedPageRaw === null;

const paginationKeys = new Set(["page", "per_page"]);
const hasOtherParams = Array.from(Astro.url.searchParams.keys()).some((key) => !paginationKeys.has(key));
const apiUrl = getApiUrl().replace(/\/$/, "");

const initialFilters = filtersFromUrl(Astro.url.searchParams, language);

let totalPosts = 0;
let countError: unknown = null;
let error: unknown = null;
let phase: string | null = null;

let allPosts: Post[] = [];

if (hasOtherParams) {
  const safeRequestedPage = Math.max(1, requestedPage);
  const offset = offsetFor(safeRequestedPage, perPage);
  const url = new URL(`${apiUrl}/api/posts/search`);
  if (initialFilters.search.trim()) url.searchParams.set("q", initialFilters.search.trim());
  if (initialFilters.from) url.searchParams.set("from", initialFilters.from);
  if (initialFilters.to) url.searchParams.set("to", initialFilters.to);
  if (initialFilters.tags.length > 0) url.searchParams.set("tags", initialFilters.tags.join(","));
  if (initialFilters.relevance) url.searchParams.set("relevance", initialFilters.relevance);
  if (initialFilters.sort) url.searchParams.set("sort", initialFilters.sort);
  if (initialFilters.scope) url.searchParams.set("scope", initialFilters.scope);

  if (initialFilters.languageMode === "current") {
    url.searchParams.set("language", language);
  } else if (initialFilters.languageMode === "selected" && initialFilters.languages.length > 0) {
    url.searchParams.set("languages", initialFilters.languages.join(","));
  } else {
    // all languages: no language param.
  }

  url.searchParams.set("limit", String(perPage));
  url.searchParams.set("offset", String(offset));

  try {
    const res = await fetch(url.toString());
    if (!res.ok) {
      error = new Error("Failed to fetch search results");
    } else {
      const payload = await res.json();
      const data = payload?.data ?? payload;
      allPosts = (data?.posts ?? []) as Post[];
      totalPosts = (data?.total ?? 0) as number;
      phase = (data?.phase ?? null) as string | null;
    }
  } catch (e) {
    error = e;
  }
} else {
  const { count: totalPostsCount, error: countErr } = await supabase
    .from("posts")
    .select("id", { count: "exact", head: true })
    .eq("language", language);

  countError = countErr;
  totalPosts = totalPostsCount ?? 0;

  const offset = offsetFor(requestedPage, perPage);
  const { data: posts, error: postsErr } = await supabase
    .from("posts")
    .select("id, titulo, slug, body, imagen_url, fecha, language")
    .eq("language", language)
    .order("fecha", { ascending: false })
    .range(offset, offset + perPage - 1);

  error = postsErr;
  allPosts = (posts || []) as Post[];
}

const totalPages = totalPagesFor(totalPosts, perPage);
const currentPage = normalizePage(requestedPage, totalPages);
const outOfRange = currentPage !== requestedPage;
const missingPageForCustomPerPage = perPage !== DEFAULT_PER_PAGE && !Astro.url.searchParams.has("page");
const canonicalizeBase = !hasOtherParams && currentPage === 1 && perPage === DEFAULT_PER_PAGE &&
  (Astro.url.searchParams.has("page") || Astro.url.searchParams.has("per_page"));

if (invalidPerPageProvided || invalidPageProvided || outOfRange || missingPageForCustomPerPage || canonicalizeBase) {
  return Astro.redirect(buildPageHref(`/${language}/`, currentPage, perPage, Astro.url.searchParams), 302);
}
const siteUrl = getSiteUrl().replace(/\/$/, "");
const canonicalPath = !hasOtherParams && currentPage === 1 && perPage === DEFAULT_PER_PAGE
  ? `/${language}/`
  : buildPageHref(`/${language}/`, currentPage, perPage, Astro.url.searchParams);
const canonicalUrl = `${siteUrl}${canonicalPath}`;
const prevPath = currentPage > 1 ? buildPageHref(`/${language}/`, currentPage - 1, perPage, Astro.url.searchParams) : null;
const nextPath = currentPage < totalPages ? buildPageHref(`/${language}/`, currentPage + 1, perPage, Astro.url.searchParams) : null;

const alternateLinks = SUPPORTED_LANGUAGES.map((lang) => ({
  lang,
  href: `${siteUrl}${buildPageHref(`/${lang}/`, currentPage, perPage)}`,
}));

const accountDeleted = Astro.url.searchParams.get("accountDeleted") === "1";
const paginationLabels = {
  previous: t(language, "pagination.previous"),
  next: t(language, "pagination.next"),
  page: t(language, "pagination.page"),
  of: t(language, "pagination.of"),
  postsPerPage: t(language, "pagination.postsPerPage"),
  show: t(language, "pagination.show"),
  goToPage: t(language, "pagination.goToPage"),
  currentPage: t(language, "pagination.currentPage"),
};
---

<BaseLayout
  title={t(language, "site.title")}
  description={t(language, "site.description")}
  canonical={canonicalUrl}
  currentLanguage={language}
  currentPath={Astro.url.pathname}
>
  <Fragment slot="head">
    {alternateLinks.map((link) => (
      <link rel="alternate" hreflang={link.lang} href={link.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}/en/`} />
    {prevPath ? <link rel="prev" href={`${siteUrl}${prevPath}`} /> : null}
    {nextPath ? <link rel="next" href={`${siteUrl}${nextPath}`} /> : null}
  </Fragment>
  <section class="bg-[var(--color-bg-subtle)] py-20 border-b border-[var(--color-border)]">
    <div class="container-responsive text-center">
      {accountDeleted ? (
        <div class="mx-auto mb-8 max-w-xl rounded-xl border border-[var(--color-success)]/25 bg-green-50 px-4 py-3 text-left">
          <p class="text-sm font-semibold text-[var(--color-success)]">
            {t(language, "deleteAccount.success")}
          </p>
        </div>
      ) : null}
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 text-[var(--color-text-primary)]">
        {t(language, "site.title")}
      </h1>
      <p class="text-xl text-[var(--color-text-secondary)] max-w-2xl mx-auto mb-8">
        {t(language, "site.description")}
      </p>
      <SearchFiltersController
        basePath={`/${language}/`}
        initialFilters={initialFilters}
        defaultFiltersOpen={false}
        client:load
      />
    </div>
  </section>

  <AdminCreatePostButton
    language={language}
    label={t(language, "createPost", "admin")}
    client:load
  />

  <section class="py-16">
    <div class="container-responsive">
      <div id="cwb-posts-root">
        <div id="cwb-posts-default">
          {(countError || error) && (
            <div class="text-center py-20">
              <p class="text-xl text-[var(--color-error)]">{t(language, "errors.fetchPosts")}</p>
            </div>
          )}
          {!(countError || error) && (
            <>
              {totalPosts === 0 ? (
                <div class="text-center py-20">
                  <p class="text-xl text-[var(--color-text-secondary)]">
                    {hasOtherParams ? t(language, "search.noResults") : t(language, "pagination.noPosts")}
                  </p>
                </div>
              ) : (
                <>
                  {hasOtherParams && initialFilters.search.trim() && phase === "content" ? (
                    <div class="mb-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-subtle)] px-4 py-3 text-sm text-[var(--color-text-secondary)]">
                      {t(language, "search.foundInContent")}
                    </div>
                  ) : null}
                  {hasOtherParams && initialFilters.search.trim() && phase === "tags" ? (
                    <div class="mb-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-subtle)] px-4 py-3 text-sm text-[var(--color-text-secondary)]">
                      {t(language, "search.foundInTags", "common", { term: initialFilters.search.trim() })}
                    </div>
                  ) : null}

                  {hasOtherParams ? (
                    <div class="mb-6 text-sm text-[var(--color-text-tertiary)]">
                      {t(language, "search.resultsCount", "common", { count: totalPosts })}
                    </div>
                  ) : null}

                  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                    {allPosts.map((post) => (
                      <PostCard post={post} language={language} />
                    ))}
                  </div>

                  <PaginationControls
                    currentPage={currentPage}
                    totalPages={totalPages}
                    perPage={perPage}
                    baseUrl={`/${language}/`}
                    labels={paginationLabels}
                    client:load
                  />
                </>
              )}
            </>
          )}
        </div>
        <div id="cwb-posts-search" class="hidden"></div>
      </div>

  </section>
</BaseLayout>
