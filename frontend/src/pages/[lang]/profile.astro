---
export const prerender = false;

import BaseLayout from "../../components/BaseLayout.astro";
import ProfilePageClient from "../../components/profile/ProfilePageClient";
import {
  DEFAULT_LANGUAGE,
  isSupportedLanguage,
  setLanguagePreference,
  t,
  type SupportedLanguage,
} from "../../lib/i18n";

const { lang } = Astro.params;
const language = isSupportedLanguage(lang ?? "") ? (lang as SupportedLanguage) : DEFAULT_LANGUAGE;

if (!lang || !isSupportedLanguage(lang)) {
  return Astro.redirect(`/${DEFAULT_LANGUAGE}/`);
}

setLanguagePreference(Astro.cookies, language);

const labels = {
  title: t(language, "profile.title"),
  adminBadge: t(language, "profile.adminBadge"),
  email: t(language, "profile.email"),
  statistics: t(language, "profile.statistics"),
  likesGiven: t(language, "profile.likesGiven"),
  dislikesGiven: t(language, "profile.dislikesGiven"),
  commentsPosted: t(language, "profile.commentsPosted"),
  likedPosts: t(language, "profile.likedPosts"),
  noLikedPosts: t(language, "profile.noLikedPosts"),
  viewAll: t(language, "profile.viewAll"),
  deleteAccount: {
    dangerZone: t(language, "profile.dangerZone"),
    deleteWarning: t(language, "profile.deleteWarning"),
    deleteAccount: t(language, "profile.deleteAccount"),
    modalTitle: t(language, "deleteAccount.modalTitle"),
    warning: t(language, "deleteAccount.warning"),
    deletedItems: {
      profile: t(language, "deleteAccount.deletedItems.profile"),
      comments: t(language, "deleteAccount.deletedItems.comments"),
      reactions: t(language, "deleteAccount.deletedItems.reactions"),
      sessions: t(language, "deleteAccount.deletedItems.sessions"),
      tokens: t(language, "deleteAccount.deletedItems.tokens"),
    },
    additionalWarning: t(language, "deleteAccount.additionalWarning"),
    confirmationPrompt: t(language, "deleteAccount.confirmationPrompt"),
    confirmationPlaceholder: t(language, "deleteAccount.confirmationPlaceholder"),
    confirmationWord: t(language, "deleteAccount.confirmationWord"),
    cancel: t(language, "deleteAccount.cancel"),
    confirmDelete: t(language, "deleteAccount.confirmDelete"),
    processing: t(language, "deleteAccount.processing"),
    success: t(language, "deleteAccount.success"),
    error: t(language, "deleteAccount.error"),
  },
} as const;
---

<BaseLayout
  title={labels.title}
  currentLanguage={language}
  currentPath={Astro.url.pathname}
>
  <Fragment slot="head">
    <meta name="robots" content="noindex, nofollow" />
  </Fragment>
  <section class="container-responsive py-12">
    <ProfilePageClient language={language} labels={labels} client:load />
  </section>
</BaseLayout>
