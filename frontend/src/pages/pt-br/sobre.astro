---
import BaseLayout from "../../components/BaseLayout.astro";
import { ArrowRight } from "lucide-astro";
import fs from "node:fs";
import path from "node:path";
import { getSiteUrl } from "../../lib/env";
import { getLocalizedPath, SUPPORTED_LANGUAGES } from "../../lib/i18n";
import { renderMarkdownHtml } from "../../lib/markdown";
import MarkdownEnhancer from "../../components/markdown/MarkdownEnhancer";
import { getMarkdownFeatureLabels } from "../../lib/markdown-labels";

const language = "pt-br";
const aboutPath = path.join(process.cwd(), "..", "content", "pt-br", "about.md");
const markdown = fs.readFileSync(aboutPath, "utf-8");
const html = renderMarkdownHtml(markdown);
const siteUrl = getSiteUrl().replace(/\/$/, "");
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
const alternateLinks = SUPPORTED_LANGUAGES.map((lang) => ({
  lang,
  href: `${siteUrl}${getLocalizedPath(Astro.url.pathname, lang)}`,
}));
const alternateUrls = {
  en: alternateLinks.find((l) => l.lang === "en")?.href,
  es: alternateLinks.find((l) => l.lang === "es")?.href,
  "pt-BR": alternateLinks.find((l) => l.lang === "pt-br")?.href,
};
const markdownLabels = getMarkdownFeatureLabels(language);
---

<BaseLayout
  title="Sobre o CodeWithBotina"
  description="Conheca Diego Alejandro Botina e a comunidade CodeWithBotina."
  canonical={canonicalUrl}
  keywords="sobre, codewithbotina, comunidade, programacao"
  alternateUrls={alternateUrls}
  currentLanguage={language}
  currentPath={Astro.url.pathname}
>
  <section class="bg-[var(--color-bg-subtle)] py-20 border-b border-[var(--color-border)]">
    <div class="container-responsive text-center">
      <div class="w-32 h-32 mx-auto bg-white rounded-full shadow-lg mb-6 overflow-hidden border-4 border-white">
        <img src="/favicon.ico" alt="Diego Alejandro Botina" class="w-full h-full object-cover" />
      </div>
      <h1 class="text-4xl font-bold mb-4">CodeWithBotina</h1>
      <p class="text-xl text-[var(--color-text-secondary)] max-w-2xl mx-auto">
        Comunidade de desenvolvimento criada por Diego Alejandro Botina.
      </p>
    </div>
  </section>

  <section class="py-16">
    <div class="container-responsive max-w-3xl">
      <article id="sobre-markdown" class="prose prose-lg mb-16">
        <Fragment set:html={html} />
        <MarkdownEnhancer containerId="sobre-markdown" language={language} labels={markdownLabels} client:load />
      </article>

      <div class="bg-[var(--color-bg-subtle)] rounded-2xl p-8 md:p-12 text-center">
        <h2 class="text-3xl font-bold mb-6">Vamos conversar</h2>
        <p class="text-[var(--color-text-secondary)] mb-8 max-w-xl mx-auto">
          Quer colaborar ou tirar alguma duvida? Voce pode me encontrar nas redes sociais ou entrar em contato pelo formulario.
        </p>

        <div class="flex flex-col sm:flex-row justify-center gap-4">
          <a href="/pt-br/contato" class="btn-primary flex items-center justify-center gap-2">
            Entrar em contato <ArrowRight size={20} />
          </a>
          <a
            href="https://portfolio.codewithbotina.com"
            target="_blank"
            rel="noreferrer"
            class="px-6 py-3 rounded-lg border border-[var(--color-border)] bg-white hover:bg-gray-50 font-semibold transition-colors flex items-center justify-center gap-2"
          >
            Ver portfolio <ArrowRight size={20} />
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
