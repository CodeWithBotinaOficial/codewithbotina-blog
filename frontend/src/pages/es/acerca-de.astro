---
import BaseLayout from "../../components/BaseLayout.astro";
import { ArrowRight } from "lucide-astro";
import { marked } from "marked";
import fs from "node:fs";
import path from "node:path";
import { getSiteUrl } from "../../lib/env";
import { getLocalizedPath, SUPPORTED_LANGUAGES } from "../../lib/i18n";

const language = "es";
const aboutPath = path.join(process.cwd(), "..", "content", "es", "about.md");
const markdown = fs.readFileSync(aboutPath, "utf-8");
const html = marked.parse(markdown);
const siteUrl = getSiteUrl().replace(/\/$/, "");
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
const alternateLinks = SUPPORTED_LANGUAGES.map((lang) => ({
  lang,
  href: `${siteUrl}${getLocalizedPath(Astro.url.pathname, lang)}`,
}));
---

<BaseLayout
  title="Acerca de CodeWithBotina"
  description="Conoce a Diego Alejandro Botina y la comunidad CodeWithBotina."
  canonical={canonicalUrl}
  currentLanguage={language}
  currentPath={Astro.url.pathname}
>
  <Fragment slot="head">
    {alternateLinks.map((link) => (
      <link rel="alternate" hreflang={link.lang} href={link.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}/en/about`} />
  </Fragment>
  <section class="bg-[var(--color-bg-subtle)] py-20 border-b border-[var(--color-border)]">
    <div class="container-responsive text-center">
      <div class="w-32 h-32 mx-auto bg-white rounded-full shadow-lg mb-6 overflow-hidden border-4 border-white">
        <img
          src="/favicon.ico"
          alt="Diego Alejandro Botina"
          class="w-full h-full object-cover"
        />
      </div>
      <h1 class="text-4xl font-bold mb-4">CodeWithBotina</h1>
      <p class="text-xl text-[var(--color-text-secondary)] max-w-2xl mx-auto">
        Comunidad de software creada por Diego Alejandro Botina.
      </p>
    </div>
  </section>

  <section class="py-16">
    <div class="container-responsive max-w-3xl">
      <article class="prose prose-lg mb-16" set:html={html} />

      <div class="bg-[var(--color-bg-subtle)] rounded-2xl p-8 md:p-12 text-center">
        <h2 class="text-3xl font-bold mb-6">Conectemos</h2>
        <p class="text-[var(--color-text-secondary)] mb-8 max-w-xl mx-auto">
          ¿Quieres colaborar o tienes preguntas? Puedes encontrarme en redes o escribirme desde el formulario de contacto.
        </p>

        <div class="flex flex-col sm:flex-row justify-center gap-4">
          <a href="/es/contacto" class="btn-primary flex items-center justify-center gap-2">
            Contáctame <ArrowRight size={20} />
          </a>
          <a
            href="https://portfolio.codewithbotina.com"
            target="_blank"
            rel="noreferrer"
            class="px-6 py-3 rounded-lg border border-[var(--color-border)] bg-white hover:bg-gray-50 font-semibold transition-colors flex items-center justify-center gap-2"
          >
            Ver portafolio <ArrowRight size={20} />
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
