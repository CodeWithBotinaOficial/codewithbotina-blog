---
export const prerender = false;

import { DEFAULT_LANGUAGE, detectLanguage, isSupportedLanguage, type SupportedLanguage } from "../../../lib/i18n";

const { slug } = Astro.params;
const langParam = Astro.url.searchParams.get("lang");
const language = isSupportedLanguage(langParam ?? "")
  ? (langParam as SupportedLanguage)
  : detectLanguage(Astro.cookies, Astro.request.headers.get("accept-language"));
const resolvedLanguage = isSupportedLanguage(language ?? "")
  ? language
  : DEFAULT_LANGUAGE;

if (!slug) {
  return Astro.redirect(`/${resolvedLanguage}/404`);
}

return Astro.redirect(`/${resolvedLanguage}/admin/edit-post/${slug}`);
---
