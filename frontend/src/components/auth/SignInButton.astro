---
const { label = "Sign in with Google" } = Astro.props;
---

<button class="btn-auth" type="button" data-auth="signin">
  {label}
</button>

<script>
  import { getAuthRoute } from "../../lib/auth-endpoints";
  const button = document.querySelector('[data-auth="signin"]');

  if (button) {
    button.addEventListener("click", () => {
      const next = encodeURIComponent(window.location.href);
      window.location.assign(`${getAuthRoute("/google")}?next=${next}`);
    });
  }
</script>
