---
const apiUrl = import.meta.env.PUBLIC_API_URL || "https://api.codewithbotina.com";
const label = "Sign in with Google";
---

<button class="btn-auth" type="button" data-auth="signin">
  {label}
</button>

<script>
  const apiUrl = "" + (import.meta.env.PUBLIC_API_URL || "https://api.codewithbotina.com");
  const button = document.querySelector('[data-auth="signin"]');

  if (button) {
    button.addEventListener("click", () => {
      const next = encodeURIComponent(window.location.href);
      window.location.assign(`${apiUrl}/api/auth/google?next=${next}`);
    });
  }
</script>
