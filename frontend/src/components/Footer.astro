---
import SocialLinks from "./SocialLinks.astro";
import { getRoutePath, t, type SupportedLanguage } from "../lib/i18n";

interface Props {
  currentLanguage: SupportedLanguage;
}

const { currentLanguage } = Astro.props;
const currentYear = new Date().getFullYear();
---

<footer class="bg-[var(--color-bg-subtle)] border-t border-[var(--color-border)] mt-auto">
  <div class="container-responsive py-12 flex flex-col items-center gap-8">
    <SocialLinks />

    <div class="flex flex-wrap justify-center gap-6 text-sm text-[var(--color-text-secondary)]">
      <a href={`/${currentLanguage}/rss.xml`} class="hover:text-[var(--color-accent-primary)] transition-colors">RSS</a>
      <a href={getRoutePath(currentLanguage, "about")} class="hover:text-[var(--color-accent-primary)] transition-colors">
        {t(currentLanguage, "nav.about")}
      </a>
      <a href={getRoutePath(currentLanguage, "contact")} class="hover:text-[var(--color-accent-primary)] transition-colors">
        {t(currentLanguage, "nav.contact")}
      </a>
      <a href={getRoutePath(currentLanguage, "privacyPolicy")} class="hover:text-[var(--color-accent-primary)] transition-colors">
        {t(currentLanguage, "footer.privacy")}
      </a>
      <a href={getRoutePath(currentLanguage, "termsOfService")} class="hover:text-[var(--color-accent-primary)] transition-colors">
        {t(currentLanguage, "footer.terms")}
      </a>
      <a href={getRoutePath(currentLanguage, "dataDeletion")} class="hover:text-[var(--color-accent-primary)] transition-colors">
        {t(currentLanguage, "footer.dataDelete")}
      </a>
      <a href={getRoutePath(currentLanguage, "cookiePolicy")} class="hover:text-[var(--color-accent-primary)] transition-colors">
        {t(currentLanguage, "footer.cookies")}
      </a>
      <a href="mailto:support@codewithbotina.com" class="hover:text-[var(--color-accent-primary)] transition-colors">
        {t(currentLanguage, "footer.support")}
      </a>
    </div>

    <div class="text-center text-sm text-[var(--color-text-tertiary)]">
      <p>{t(currentLanguage, "footer.copyright", "common", { year: currentYear })}</p>
      <p class="mt-2">{t(currentLanguage, "footer.builtWith")}</p>
    </div>
  </div>
</footer>
