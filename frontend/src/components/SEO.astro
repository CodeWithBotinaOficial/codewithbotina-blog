---
interface Props {
  title: string;
  description: string;
  keywords?: string;
  image?: string;
  type?: "website" | "article";
  author?: string;
  publishedTime?: string;
  modifiedTime?: string;
  // Locale for meta + OG locale. Use BCP 47 for hreflang/locale (e.g. pt-BR).
  locale?: "es" | "en" | "pt-BR";
  alternateUrls?: {
    es?: string;
    en?: string;
    "pt-BR"?: string;
  };
  canonical?: string;
}

const {
  title,
  description,
  keywords = "",
  image = "/og-image.png",
  type = "website",
  author = "CodeWithBotina",
  publishedTime,
  modifiedTime,
  locale = "es",
  alternateUrls,
  canonical,
} = Astro.props;

const siteUrl = "https://blog.codewithbotina.com";
const siteName = "CodeWithBotina";
const fullTitle = title === siteName ? title : `${title} | ${siteName}`;
const metaDescription = description;

// Avoid depending on request host headers; default to the canonical production origin.
const canonicalUrl = canonical || `${siteUrl}${Astro.url.pathname}`;
const imageUrl = image.startsWith("http") ? image : `${siteUrl}${image.startsWith("/") ? image : `/${image}`}`;
const ogLocale = locale.replace("-", "_");
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" sizes="any" href="/favicon.svg" />
<link rel="icon" type="image/x-icon" href="/favicon.ico" />
<meta name="generator" content={Astro.generator} />

<!-- Primary Meta Tags -->
<title>{fullTitle}</title>
<meta name="title" content={fullTitle} />
<meta name="description" content={metaDescription} />
{keywords && <meta name="keywords" content={keywords} />}
<meta name="author" content={author} />
<meta name="robots" content="index, follow" />
<meta name="language" content={locale} />
<link rel="canonical" href={canonicalUrl} />

{alternateUrls && (
  <>
    {alternateUrls.es && <link rel="alternate" hreflang="es" href={alternateUrls.es} />}
    {alternateUrls.en && <link rel="alternate" hreflang="en" href={alternateUrls.en} />}
    {alternateUrls["pt-BR"] && <link rel="alternate" hreflang="pt-BR" href={alternateUrls["pt-BR"]} />}
    <link rel="alternate" hreflang="x-default" href={alternateUrls.en || alternateUrls.es || canonicalUrl} />
  </>
)}

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={metaDescription} />
<meta property="og:image" content={imageUrl} />
<meta property="og:locale" content={ogLocale} />
<meta property="og:site_name" content="CodeWithBotina Blog" />

{type === "article" && (
  <>
    {author && <meta property="article:author" content={author} />}
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
  </>
)}

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalUrl} />
<meta property="twitter:title" content={fullTitle} />
<meta property="twitter:description" content={metaDescription} />
<meta property="twitter:image" content={imageUrl} />
<meta name="twitter:creator" content="@CodeWithBotina" />

<!-- Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

<!-- Performance: API preconnect -->
<link rel="preconnect" href="https://api.codewithbotina.com" />
<link rel="dns-prefetch" href="https://api.codewithbotina.com" />
