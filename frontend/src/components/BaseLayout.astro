---
import Header from "./Header.astro";
import Footer from "./Footer.astro";
import SEO from "./SEO.astro";
import CookieConsent from "./CookieConsent.tsx";
import "../styles/global.css";
import { DEFAULT_LANGUAGE, isSupportedLanguage, toHreflang } from "../lib/i18n";
interface Props {
  title: string;
  description?: string;
  keywords?: string;
  image?: string;
  type?: 'website' | 'article';
  canonical?: string;
  author?: string;
  publishedTime?: string;
  modifiedTime?: string;
  alternateUrls?: {
    es?: string;
    en?: string;
    "pt-BR"?: string;
  };
  currentLanguage?: string;
  currentPath?: string;
  currentPostId?: string;
  hideChrome?: boolean;
}

const {
  title,
  description = "Technical insights on software development, web technologies, and programming best practices.",
  keywords,
  image,
  type,
  canonical,
  author,
  publishedTime,
  modifiedTime,
  alternateUrls,
  currentLanguage = DEFAULT_LANGUAGE,
  currentPath = Astro.url.pathname,
  currentPostId,
  hideChrome = false,
} = Astro.props;

const googleSiteVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;
---

<!doctype html>
<html lang={currentLanguage}>
  <head>
    <SEO
      title={title}
      description={description}
      keywords={keywords}
      image={image}
      type={type}
      canonical={canonical}
      author={author}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      locale={toHreflang(isSupportedLanguage(currentLanguage) ? currentLanguage : DEFAULT_LANGUAGE) as "es" | "en" | "pt-BR"}
      alternateUrls={alternateUrls}
    />
    {googleSiteVerification && (
      <meta
        name="google-site-verification"
        content={googleSiteVerification}
      />
    )}
    <link
      rel="alternate"
      type="application/rss+xml"
      title="CodeWithBotina RSS Feed"
      href={`/${currentLanguage}/rss.xml`}
    />
    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col">
    {!hideChrome && (
      <Header currentLanguage={currentLanguage} currentPath={currentPath} currentPostId={currentPostId} />
    )}
    <main class="flex-1">
      <slot />
    </main>
    {!hideChrome && (
      <>
        <Footer currentLanguage={currentLanguage} />
        <CookieConsent language={currentLanguage} client:load />
      </>
    )}
  </body>
</html>
